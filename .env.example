# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Log verbosity: trace | debug | info | warn | error
PULSEDB_LOG_LEVEL=info

# Admin password — generated once on first start if not set.
# Set this to avoid regenerating on every container restart.
PULSEDB_ADMIN_PASSWORD=change-me-strong-password

# WAL encryption key (optional) — 64 hex chars = 32 bytes.
# Generate with: openssl rand -hex 32
# PULSEDB_WAL_KEY=
