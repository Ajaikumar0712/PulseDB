# PulseDB configuration — copy this file to .env and fill in your values.
# NEVER commit .env to git (it is already in .gitignore).

# Log verbosity: trace | debug | info | warn | error
PULSEDB_LOG_LEVEL=info

# Admin password.
# On first start PulseDB generates a random password and prints it once.
# Set this to avoid regenerating on every restart.
PULSEDB_ADMIN_PASSWORD=change-me-strong-password

# WAL encryption key (optional).
# 64 hex characters = 32 bytes of AES-256-GCM key.
# Generate with:  openssl rand -hex 32
# PULSEDB_WAL_KEY=

# TLS certificate paths (optional).
# Enable by also passing --tls-cert / --tls-key to pulsedb-server.
# PULSEDB_TLS_CERT=cert.pem
# PULSEDB_TLS_KEY=key.pem
